# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------

# API key from ThreatLocker Portal → Modules → API
THREATLOCKER_API_KEY=your-api-key-here

# Default organization GUID. Find it in the portal URL after switching
# into the org you want as the default (e.g. ?orgId=xxxxxxxx-...).
THREATLOCKER_ORG_ID=00000000-0000-0000-0000-000000000000

# Your portal API base URL — use the same subdomain letter shown in the
# portal (h, g, e, …). Example: https://portalapi.h.threatlocker.com
THREATLOCKER_BASE_URL=https://portalapi.h.threatlocker.com

# -----------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------

# Per-request timeout in seconds (default: 30)
# THREATLOCKER_TIMEOUT=30

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# HTTP transport bind address (default: 127.0.0.1 — loopback only)
# MCP_HTTP_HOST=127.0.0.1

# HTTP transport port (default: 8765)
# MCP_HTTP_PORT=8765
